# Default database connection (fallback when per-service vars are not set)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD="your_password_here"

# Admin Service database (admin_db -- central management)
ADMIN_DB_NAME=admin_db
# ADMIN_DB_HOST=localhost
# ADMIN_DB_PORT=5432
# ADMIN_DB_USER=postgres
# ADMIN_DB_PASSWORD="secret"

# Shared database (shared_db -- normal tenant data + access control)
SHARED_DB_NAME=shared_db
# SHARED_DB_HOST=localhost
# SHARED_DB_PORT=5432
# SHARED_DB_USER=postgres
# SHARED_DB_PASSWORD="secret"

# Keycloak
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=cargoez

# Services
ADMIN_SERVICE_PORT=3001
ADMIN_SERVICE_URL=http://localhost:3001
FREIGHT_SERVICE_PORT=3002
CONTACTS_SERVICE_PORT=3003
BOOKS_SERVICE_PORT=3004
API_PORTAL_PORT=4000
