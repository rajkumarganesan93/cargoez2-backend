{
  "name": "@cargoez/source",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nx run-many -t build",
    "build:affected": "nx affected -t build",
    "test": "nx run-many -t test",
    "test:affected": "nx affected -t test",
    "lint": "nx run-many -t lint",
    "lint:affected": "nx affected -t lint",
    "start:user": "nx serve user-service",
    "start:shared": "nx serve shared-db-example",
    "start:portal": "nx serve api-portal",
    "start:all": "nx run-many -t serve --parallel=3",
    "dev:user": "node -r ./register-paths.js dist/apps/user-service/src/main.js",
    "dev:shared": "node -r ./register-paths.js dist/apps/shared-db-example/src/main.js",
    "dev:portal": "node -r ./register-paths.js dist/apps/api-portal/src/main.js",
    "migrate:user": "nx run user-service:migrate",
    "migrate:shared": "nx run shared-db-example:migrate",
    "graph": "nx graph"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/swagger": "^11.2.0",
    "@nestjs/websockets": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "knex": "^3.1.0",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "express": "^4.21.0",
    "swagger-ui-express": "^5.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nx/js": "22.5.3",
    "@nx/nest": "22.5.3",
    "@nx/workspace": "22.5.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.16",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "nx": "22.5.3",
    "typescript": "^5.7.0",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.0"
  },
  "engines": {
    "node": ">=18.7.0"
  }
}
